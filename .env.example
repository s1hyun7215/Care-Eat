# ===== 프론트엔드 (VITE_ 접두사 필수) =====

# 네이버 쇼핑 검색 API (developers.naver.com)
VITE_NAVER_CLIENT_ID=your_naver_client_id_here
VITE_NAVER_CLIENT_SECRET=your_naver_client_secret_here

# 공공데이터 - 식약처 레시피 API
VITE_FOOD_API_KEY=your_food_api_key_here


# ===== 백엔드 전용 (backend/.env 또는 프로젝트 루트 .env) =====
# VITE_ 접두사 없음 → 브라우저에 노출되지 않음

# Google Gemini API (AI Studio에서 발급)
GEMINI_API_KEY=your_gemini_api_key_here
